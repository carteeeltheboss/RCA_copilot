#
# From rca_copilot
#

# (string value)
#worker_state_key = correlation_worker_v1

# (string value)
#version = correlation-v1

# (integer value)
# Minimum value: 1
#batch_size = 100

# (floating point value)
# Minimum value: 0.1
#poll_interval_seconds = 2.0

# (integer value)
# Minimum value: 0
#request_id_max_gap_seconds = 300

# (integer value)
# Minimum value: 0
#resource_id_max_gap_seconds = 600

# (integer value)
# Minimum value: 1
#max_events_per_group = 100

# (boolean value)
#skip_periodic_groups = true

# (string value)
#health_file = /var/lib/rca-copilot/correlation-worker.health


