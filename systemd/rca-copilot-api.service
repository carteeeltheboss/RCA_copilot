[Unit]
Description=RCA Copilot API
After=network-online.target mongod.service

[Service]
User=rca-copilot
Group=rca-copilot
RuntimeDirectory=rca-copilot
StateDirectory=rca-copilot
ExecStart=/usr/bin/rca-copilot-api --config-file /etc/rca-copilot/rca-copilot.conf
Restart=on-failure

[Install]
WantedBy=multi-user.target
