[Unit]
Description=RCA Copilot enrichment worker
After=network-online.target mongod.service
[Service]
User=rca-copilot
Group=rca-copilot
StateDirectory=rca-copilot
ExecStart=/usr/bin/rca-copilot-enrichment-worker --config-file /etc/rca-copilot/rca-copilot.conf
Restart=on-failure
RestartSec=5s
[Install]
WantedBy=multi-user.target
